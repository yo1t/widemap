# Widemap environment variables example
#
# Runtime settings are saved to .widemap.json after startup.
# Use this file only for startup defaults or reverse-proxy deployment settings.
# Copy to .env for local use. Do not commit .env.

PORT=3000
POLL_INTERVAL_MS=60000

# ASUS router default. You can also set this later from the settings UI.
# ROUTER_IP=192.168.1.1

# Yamaha RTX SSH defaults. You can also set these later from the settings UI.
# YAMAHA_IP=192.168.1.1
# YAMAHA_USER=admin
# YAMAHA_PASS=
# YAMAHA_NAT=100

# Reverse proxy sub-path, for example https://example.com/widemap
# SUBPATH=/widemap
