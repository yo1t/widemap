# Widemap 環境変数サンプル
# 実運用では .widemap.json（管理者トークンと一緒に自動生成）か、このファイルをコピーした .env で設定
# どちらも .gitignore 対象

PORT=3000
POLL_INTERVAL_MS=2000

# === ASUS ルーター（任意。設定UI から後で入力可） ===
# ROUTER_IP=192.168.1.1
# ROUTER_USER=
# ROUTER_PASS=

# === Yamaha RTX (SSH) ===
# YAMAHA_IP=192.168.1.1
# YAMAHA_USER=
# YAMAHA_PASS=
# YAMAHA_NAT=100

# === リバースプロキシ配下で使う場合 ===
# SUBPATH=/widemap
