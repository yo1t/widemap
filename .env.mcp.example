# EgressView MCP Server — environment variables
# Copy to .env.mcp and fill in your values. Do not commit .env.mcp.
#
# Usage:
#   stdio mode (local):  EGRESSVIEW_URL=... EGRESSVIEW_TOKEN=... node mcp-server.js
#   HTTP mode (remote):  MCP_PORT=3010 EGRESSVIEW_URL=... EGRESSVIEW_TOKEN=... node mcp-server.js

# URL of the running EgressView server (no trailing slash)
# Local:  http://localhost:3002
# Remote: http://your-server-ip:3002
EGRESSVIEW_URL=http://localhost:3002

# Admin token — shown in the EgressView console on first startup,
# also stored in .egressview.json as "adminToken"
EGRESSVIEW_TOKEN=

# HTTP transport: port for the MCP HTTP server (omit for stdio mode)
# MCP_PORT=3010

# Auth token for the MCP HTTP endpoint.
# Defaults to EGRESSVIEW_TOKEN when not set.
# Set to a different value to use separate tokens for MCP and EgressView API.
# MCP_TOKEN=
