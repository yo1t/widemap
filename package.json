{
  "name": "egressview",
  "version": "1.2.0",
  "description": "EgressView — Where Is Data Exiting? Map All Paths. Real-time visualisation of LAN devices and their internet destinations.",
  "author": {
    "name": "yo1t",
    "url": "https://github.com/yo1t"
  },
  "license": "AGPL-3.0-only",
  "homepage": "https://yo1t.github.io/egressview/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yo1t/egressview.git"
  },
  "bugs": {
    "url": "https://github.com/yo1t/egressview/issues"
  },
  "keywords": [
    "network-monitoring",
    "egress",
    "home-network",
    "soho",
    "security",
    "yamaha-rtx",
    "iot",
    "threat-intelligence"
  ],
  "engines": {
    "node": ">=18"
  },
  "main": "server.js",
  "files": [
    "server.js",
    "mcp-server.js",
    "public/",
    "src/",
    "scripts/",
    "docs/*.md",
    "docs/*.png",
    "index.html",
    "index.ja.html",
    "sitemap.xml",
    "_config.yml",
    ".env.example",
    ".env.mcp.example",
    ".egressview.json.example",
    "README.md",
    "README.ja.md",
    "CHANGELOG.md",
    "ROADMAP.md",
    "ROADMAP.ja.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test test/unit/*.test.js",
    "test:unit": "node --test test/unit/*.test.js",
    "test:integration": "RUN_INTEGRATION=1 node --test test/integration/*.test.js",
    "test:smoke": "playwright test",
    "security:audit": "npm audit --omit=dev --audit-level=moderate",
    "security:secrets": "node scripts/secret-scan.js",
    "security:check": "npm run security:audit && npm run security:secrets",
    "release:check": "npm run test:unit && npm run security:check && npm pack --dry-run",
    "mcp": "node mcp-server.js",
    "gen:demo-db": "node scripts/gen-demo-db.js",
    "deploy:ec2": "bash scripts/deploy-ec2.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.7.0",
    "better-sqlite3": "^12.10.0",
    "bonjour-service": "^1.2.1",
    "dotenv": "^16.4.0",
    "express": "^4.18.0",
    "socket.io": "^4.7.0",
    "ssh2": "^1.17.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "socket.io-client": "^4.8.3"
  }
}
